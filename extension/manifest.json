{
  "manifest_version": 3,
  "name": "PocketSelectAI",
  "version": "1.0.0",
  "description": "Highlight any text on the web and get an instant AI explanation.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "http://localhost:8000/*",
    "https://ai-text-highlighter.onrender.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["tooltip.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/pocket-icon16.png",
    "48": "icons/pocket-icon48.png",
    "128": "icons/pocket-icon128.png"
  },

  "action": {
    "default_title": "PocketSelectAI",
    "default_popup": "popup.html"
  },

  "commands": {
    "toggle-snip": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Toggle screen snip mode"
    }
  }
}
